# Confluence audit integration
#
# The integration polls the Confluence audit API through the Atlassian API
# gateway. Replace <cloud-id> with your site's cloud id, shown at:
#   https://<your-site>.atlassian.net/_edge/tenant_info
# Values are read literally by the poller; ${VAR} substitution is NOT
# supported, so the cloud id must be written inline.
#
# When CONFLUENCE_AUDIT_PATH is a full https:// URL it is used as the
# complete request URL and CONFLUENCE_BASE_URL is not part of the request.
# Still keep CONFLUENCE_BASE_URL set to your real site URL (no trailing
# slash): its hostname labels every event's conf_site_host field.
CONFLUENCE_BASE_URL=https://your-site.atlassian.net
CONFLUENCE_AUDIT_PATH=https://api.atlassian.com/ex/confluence/<cloud-id>/wiki/rest/api/audit

# Alternative endpoint (relative paths are appended to CONFLUENCE_BASE_URL):
#   Direct site URL, no gateway:  CONFLUENCE_AUDIT_PATH=/wiki/rest/api/audit

# Authentication mode:
#   basic  - Confluence Cloud email/API token
#   bearer - personal access token or reverse-proxy bearer token
#   auto   - bearer if CONFLUENCE_BEARER_TOKEN/CONFLUENCE_PAT is set,
#            otherwise basic if username+token are set
CONFLUENCE_AUTH_MODE=auto

# Basic auth settings. For Confluence Cloud, use the user's email and API token.
CONFLUENCE_USERNAME=<confluence admin email>
CONFLUENCE_API_TOKEN=<atlassian api token>
# CONFLUENCE_API_TOKEN_FILE=/var/ossec/etc/confluence-api-token.secret

# Bearer/PAT auth settings.
# CONFLUENCE_BEARER_TOKEN=<confluence bearer token>
# CONFLUENCE_PAT=<confluence personal access token>
# CONFLUENCE_BEARER_TOKEN_FILE=/var/ossec/etc/confluence-bearer-token.secret

# First-run backfill window. Later runs query from the saved high-water mark
# with a dedupe lookback so late-arriving records are not missed.
CONFLUENCE_BACKFILL_HOURS=24
CONFLUENCE_LOOKBACK_SECONDS=300
CONFLUENCE_SEEN_RETENTION_HOURS=48

# Pagination and HTTP behavior.
CONFLUENCE_LIMIT=1000
CONFLUENCE_MAX_PAGES=10
CONFLUENCE_HTTP_TIMEOUT=60
CONFLUENCE_SLEEP_BETWEEN_PAGES=0.5

# Confluence audit query date format:
#   date     2026-07-04
#   iso      2026-07-04T10:00:00.000Z
#   epoch_ms 1783159200000
CONFLUENCE_DATE_FORMAT=epoch_ms
CONFLUENCE_INCLUDE_END_DATE=true

# Optional server-side search and extra query params.
# CONFLUENCE_SEARCH_STRING=
# CONFLUENCE_EXTRA_QUERY=

CONFLUENCE_DEBUG=false
